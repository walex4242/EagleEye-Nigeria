# ─────────────────────────────────────────────
# EagleEye-Nigeria — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to Git
# ─────────────────────────────────────────────

# ── NASA FIRMS ────────────────────────────────
# Get your key at: https://firms.modaps.eosdis.nasa.gov/api/area/
NASA_FIRMS_API_KEY=your_nasa_firms_api_key_here

# ── Google Earth Engine ───────────────────────
# Service account email from GEE console
GEE_SERVICE_ACCOUNT=your-service-account@your-project.iam.gserviceaccount.com
# Path to your downloaded GEE service account JSON key
GEE_KEY_FILE=service_account.json

# ── ACLED (Conflict Data) ─────────────────────
# Register at: https://acleddata.com/register/
ACLED_API_KEY=your_acled_api_key_here
ACLED_EMAIL=your_email@example.com

# ── Sentinel-2 / Copernicus ───────────────────
# Register at: https://dataspace.copernicus.eu/
COPERNICUS_USER=your_copernicus_username
COPERNICUS_PASSWORD=your_copernicus_password

# ── App Settings ──────────────────────────────
APP_ENV=development        # development | production
APP_PORT=8000
SECRET_KEY=change_this_to_a_long_random_string

# ── Database (optional, for event logging) ────
DATABASE_URL=sqlite:///./eagleeye.db

# ── Strategic Delay (minutes) ─────────────────
# Public-facing data will be delayed by this many minutes
PUBLIC_DATA_DELAY_MINUTES=60
