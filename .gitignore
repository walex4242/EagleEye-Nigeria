# ══════════════════════════════════════
# EagleEye-Nigeria .gitignore
# ══════════════════════════════════════

# ── Environment & Secrets ──
.env
.env.*
!.env.example
*.pem
*.key
*.cert

# ── Google Cloud / GEE Credentials ──
credentials.json
service_account.json
*-service-account.json
focuselite-*.json
**/earthengine/credentials

# ── Python ──
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# ── Virtual Environments ──
.venv/
venv/
ENV/
env/

# ── Jupyter ──
.ipynb_checkpoints/
*.ipynb

# ══════════════════════════════════════
# ML — Keep code, EXCLUDE all data
# ══════════════════════════════════════
ml/data/
ml/logs/
ml/weights/
ml/runs/
ml/__pycache__/

# ── Model files ──
*.pt
*.pth
*.onnx
*.pkl
*.h5
*.safetensors

# ── Image datasets ──
*.png
*.jpg
*.jpeg
*.bmp
*.tif
*.tiff
!dashboard/static/**/*.png
!dashboard/static/**/*.jpg
!static/**/*.png
!static/**/*.jpg

# ── Geospatial data ──
*.shp
*.shx
*.dbf
*.prj
*.geojson
!dashboard/static/**/*.geojson

# ── App data caches ──
data/alerts/
data/geocode_cache/
data/sentinel2_cache/
data/snapshots/
data/raw/
data/processed/

# ── Database ──
*.db
*.sqlite
*.sqlite3

# ── Logs ──
*.log
logs/

# ── Test cache ──
.pytest_cache/
.coverage
htmlcov/

# ── OS ──
.DS_Store
Thumbs.db

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo